# ai-collab configuration
# Copy to .env and customize

# Database path (default: .data/brainstorm.db)
# BRAINSTORM_DB=.data/brainstorm.db

# Save agent responses to files for debugging (default: false)
# AI_COLLAB_SAVE_RESPONSES=false

# Directory for saved responses (default: .brainstorm/)
# AI_COLLAB_RESPONSES_DIR=.brainstorm
