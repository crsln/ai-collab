# ai-collab agent configuration
# Copy to ai-collab.toml and customize
# Only enable agents whose CLI tools you have installed

[settings]
db_path = ".data/brainstorm.db"
default_timeout = 900  # 15 minutes

# Each [agents.NAME] section defines an AI CLI agent.
# Required fields: command, args
# Optional fields: model, timeout, enabled, display_name, description

[agents.copilot]
enabled = true
command = "copilot"
args = ["-p", "{prompt}", "--allow-all", "--allow-tool", "brainstorm", "atlas"]
# model = ""  # uses CLI default
# timeout = 900
display_name = "GitHub Copilot"
description = "Code analysis, shell commands, git operations, GitHub CLI"

[agents.gemini]
enabled = true
command = "gemini"
args = ["-p", "{prompt}", "--yolo"]
# model = ""
# timeout = 900
display_name = "Google Gemini"
description = "Architecture analysis, research, alternative approaches, documentation"

# OpenAI Codex CLI — uses CodexProvider (subclass of GenericCLIProvider)
# Enable if you have the Codex CLI installed. Opt-in by default.
[agents.codex]
enabled = false
command = "codex"
args = ["exec", "-p", "{prompt}", "--full-auto"]
display_name = "OpenAI Codex"
description = "Code generation, file editing, implementing specs from plans"

# Example: Aider
# [agents.aider]
# enabled = false
# command = "aider"
# args = ["--message", "{prompt}"]
# display_name = "Aider"
# description = "AI pair programming"

# Claude Haiku validator — uses Haiku for response quality checking
[agents.validator]
enabled = true
command = "claude"
args = ["-p", "{prompt}", "--allowedTools", "mcp__brainstorm__bs_update_quality"]
model = "claude-haiku-4-5-20251001"
timeout = 30.0
display_name = "Response Validator"
description = "Classifies agent responses as valid/invalid/empty using Haiku"

# Example: Custom CLI agent
# [agents.my_agent]
# enabled = false
# command = "my-ai-tool"
# args = ["--prompt", "{prompt}"]
# timeout = 300
# display_name = "My Custom Agent"
# description = "Custom AI tool integration"
